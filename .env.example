# pymrsf Configuration Example
# Copy this file to .env and fill in your settings

# ──────────────────────────────────────────────────────────────────────────────
# Provider Selection (choose one)
# ──────────────────────────────────────────────────────────────────────────────

# Option 1: OpenAI (easiest to get started, no model download)
# Requires: pip install pymrsf[openai]
# PYMRSF_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# PYMRSF_MODEL_VERSION=gpt-3.5-turbo  # or gpt-4, gpt-4o

# Option 2: Anthropic (easy to get started, no model download)
# Requires: pip install pymrsf[anthropic]
# PYMRSF_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# PYMRSF_MODEL_VERSION=claude-3-5-sonnet-20241022

# Option 3: Local Model (full features, requires 4GB+ model download)
# Requires: pip install pymrsf[local]
PYMRSF_PROVIDER=local
PYMRSF_MODEL_PATH=./models/mistral-7b-v0.1.Q4_K_M.gguf
PYMRSF_N_GPU_LAYERS=0  # set to 20-30 if you have a GPU
PYMRSF_N_CTX=4096  # context window size
PYMRSF_N_THREADS=8  # CPU threads (default: auto-detect)

# ──────────────────────────────────────────────────────────────────────────────
# Advanced Settings (optional)
# ──────────────────────────────────────────────────────────────────────────────

# Logit precision for local models (default: 6)
# PYMRSF_LOGIT_PRECISION=6

# Surprise threshold for OpenAI provider (default: -1.0)
# Lower = more surprises detected
# PYMRSF_SURPRISE_THRESHOLD=-1.0

# ──────────────────────────────────────────────────────────────────────────────
# Feature Availability by Provider
# ──────────────────────────────────────────────────────────────────────────────
#
# ✅ Local:     RAG scoring, knowledge probing, delta compression (all features)
# ✅ OpenAI:    RAG scoring (basic, uses logprobs API)
# ✅ Anthropic: RAG scoring (relevance-only, no novelty detection)
#
# For lightweight trial: Use OpenAI or Anthropic
# For production/advanced: Use local model
# ──────────────────────────────────────────────────────────────────────────────
